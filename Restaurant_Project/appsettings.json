    "Serilog": {
        "MinimumLevel": {
            "Default": "Debug",
            "Override": {
                "Microsoft": "Information"
            }
        },
        "Using": [
            "Serilog.Sinks.File",
            "Serilog.Sinks.Seq"
        ],
        "WriteTo": [
            {
                "Name": "File",
                "Args": {
                    "path": "logs/log.txt",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 7,
                    "fileSizeLimitBytes": 10485760,
                    "rollOnFileSizeLimit": true
                }
            },
            {
                "Name": "Seq",
                "Args": {
                    "serverUrl": "https://localhost:7168/"
                }
            }
        ],
        "Enrich": [
            "FromLogContext"
        ]
    },
    "IpRateLimiting": {
        "EnableEndpointRateLimiting": true,
        "StackBlockedRequests": false,
        "RealIpHeader": "X-Real-IP",
        "ClientIdHeader": "X-ClientId",
        "HttpStatusCode": 429,
        "GeneralRules": [
            {
                "Endpoint": "*",
                "Period": "1s",
                "Limit": 10
            },
            {
                "Endpoint": "*",
                "Period": "1m",
                "Limit": 100
            },
            {
                "Endpoint": "post:/api/auth/*",
                "Period": "1m",
                "Limit": 5
            }
        ]
    },
    "IpRateLimitPolicies": {
        "IpRules": []
    }
